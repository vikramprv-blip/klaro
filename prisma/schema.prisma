generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id            String           @id @default(cuid())
  name          String
  email         String           @unique
  role          String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  assignments   WorkAssignment[]
  createdItems  WorkItem[]       @relation("CreatedBy")
  reviewedItems WorkItem[]       @relation("ReviewedBy")
}

model Client {
  id            String      @id @default(cuid())
  name          String
  code          String?     @unique
  email         String?
  phone         String?
  address       String?
  gstin         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  workItems     WorkItem[]
  invoices      Invoice[]
}

model WorkItem {
  id                String           @id @default(cuid())
  title             String
  description       String?
  filingType        String
  periodLabel       String?
  dueDate           DateTime?
  completedAt       DateTime?
  filedAt           DateTime?

  status            String           @default("PENDING")
  priority          String?
  invoiceTriggered  Boolean          @default(false)

  clientId          String
  client            Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)

  createdById       String?
  createdBy         User?            @relation("CreatedBy", fields: [createdById], references: [id])

  reviewedById      String?
  reviewedBy        User?            @relation("ReviewedBy", fields: [reviewedById], references: [id])

  documents         WorkDocument[]
  assignments       WorkAssignment[]
  invoice           Invoice?

  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([clientId, status])
  @@index([dueDate])
  @@index([filingType])
}

model WorkDocument {
  id            String       @id @default(cuid())
  name          String
  docType       String?
  status        String       @default("MISSING")
  fileUrl       String?
  uploadedAt    DateTime?
  notes         String?

  workItemId    String
  workItem      WorkItem     @relation(fields: [workItemId], references: [id], onDelete: Cascade)

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([workItemId, status])
}

model WorkAssignment {
  id            String       @id @default(cuid())
  role          String       @default("OWNER")
  assignedAt    DateTime     @default(now())
  unassignedAt  DateTime?

  workItemId    String
  workItem      WorkItem     @relation(fields: [workItemId], references: [id], onDelete: Cascade)

  userId        String
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, workItemId])
}

model Invoice {
  id            String       @id @default(cuid())
  invoiceNo     String?      @unique
  amount        Decimal?
  status        String       @default("NOT_TRIGGERED")
  triggeredAt   DateTime?
  sentAt        DateTime?
  paidAt        DateTime?

  clientId      String
  client        Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)

  workItemId    String       @unique
  workItem      WorkItem     @relation(fields: [workItemId], references: [id], onDelete: Cascade)

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([clientId, status])
}
