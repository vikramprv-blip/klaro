generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["auth", "public"]
}

model Client {
  id        String      @id @default(cuid())
  organizationId String?
  code      String?
  name      String
phone String?
  email     String?
  address   String?
  gstin     String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  documents documents[]
  invoices  Invoice[]
  workItems WorkItem[]
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@schema("public")
}

model Invoice {
  id        String    @id @default(cuid())
  number    String
  amount    Float
  status    String
  dueDate   DateTime?
  clientId  String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  client    Client?   @relation(fields: [clientId], references: [id])

  @@schema("public")
}

model WorkItem {
  id          String    @id @default(cuid())
  organizationId String?
  title       String
  description String?
  status      String    @default("TODO")
  priority    String    @default("MEDIUM")
  dueDate     DateTime?
  clientId    String?
  assigneeId  String?   @db.Uuid
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
lastFollowedUpAt DateTime?
  client      Client?       @relation(fields: [clientId], references: [id])
  assignee    users?        @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
  followUps   FollowUpLog[]
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([assigneeId])
  @@index([organizationId])
  @@schema("public")
}

model FollowUpLog {
  id         String   @id @default(cuid())
  workItemId String
  message    String
  createdAt  DateTime @default(now())

  workItem   WorkItem @relation(fields: [workItemId], references: [id], onDelete: Cascade)

  @@index([workItemId])
  @@index([createdAt])
  @@schema("public")
}

model ServiceTemplate {
  id             String   @id @default(cuid())
  name           String
phone String?
  code           String?  @unique
  description    String?
  department     String?
  frequency      String   @default("ONCE")
  dueDayOfMonth  Int?
  dueMonthOfYear Int?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@schema("public")
}

